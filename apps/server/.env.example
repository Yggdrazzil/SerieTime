NODE_ENV=development
PORT=4000
DATABASE_URL="file:../data/serietime.sqlite"
APP_NAME="SerieTime"
APP_URL="http://localhost:4000"
APP_SECRET="change-me"
JWT_SECRET="change-me"
SESSION_DURATION_DAYS=30
TMDB_API_KEY=""
TMDB_READ_ACCESS_TOKEN=""

# SSO (optionnel) — laissez vide pour n'utiliser que l'e-mail / mot de passe.
# GOOGLE_CLIENT_IDS = Client IDs OAuth acceptés (Web/Android/iOS), séparés par des virgules.
GOOGLE_CLIENT_IDS=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

TVMAZE_ENABLED=true
TVDB_ENABLED=false
TVDB_API_KEY=""
TVDB_PIN=""
DEFAULT_LANGUAGE="fr-FR"
DEFAULT_COUNTRY="FR"
DEFAULT_TIMEZONE="Europe/Paris"
MAX_IMPORT_ZIP_SIZE_MB=100
CORS_ALLOWED_ORIGINS="http://localhost:5173,capacitor://localhost,https://localhost"
