// SerieTime — schéma Prisma (spec §13).
// SQLite ne supporte ni les enums natifs ni le type Json :
// les enums de la spec sont des String contraints par Zod côté API,
// les champs *Json sont des String contenant du JSON sérialisé.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String?
  displayName  String
  avatarUrl    String?
  coverUrl     String?
  birthYear    Int?
  gender       String?
  countryCode  String   @default("FR")
  passwordHash String?
  // Identité d'authentification : "password" (fallback e-mail/mdp) ou "google" | "facebook" | "apple" (SSO).
  // provider/providerId = méthode d'origine (rétro-compat). Les colonnes ci-dessous
  // permettent de LIER plusieurs méthodes à un même compte (SSO + mot de passe).
  provider     String   @default("password")
  providerId   String?
  googleId     String?  @unique
  facebookId   String?  @unique
  appleId      String?  @unique
  discordId    String?  @unique
  // Social : un profil privé n'est visible que de ses abonnés (et de lui-même).
  isPrivate    Boolean  @default(false)
  // Langue de contenu (titres/résumés des séries et films) : fr par défaut.
  language     String   @default("fr")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mediaStatuses   UserMediaStatus[]
  episodeStatuses UserEpisodeStatus[]
  watchEvents     WatchEvent[]
  lists           MediaList[]
  notifications   Notification[]
  ratings         Rating[]
  sessions        Session[]

  // Graphe social (abonnements asymétriques, façon TV Time).
  following       Follow[]          @relation("following")
  followers       Follow[]          @relation("followers")
  comments        Comment[]
  reactions       CommentReaction[]

  // Gamification (spec 2026-07-16 §7).
  progress        UserProgress?
  badges          UserBadge[]
  challenges      UserChallenge[]

  // Réinitialisation du mot de passe via ré-authentification SSO.
  passwordResetTokens PasswordResetToken[]

  // Mémoire du flux Explorer (items déjà servis, exclus du tirage 3 jours).
  exploreImpressions ExploreImpression[]

  // Réglages applicatifs PAR UTILISATEUR (notifs, thème, abonnements…).
  setting            UserSetting?

  // Signalements d'œuvres/commentaires inappropriés émis par cet utilisateur.
  reports            Report[]

  // Blocages (modération UGC) : comptes que JE bloque / comptes qui me bloquent.
  blocking           Block[]  @relation("blocking")
  blockedBy          Block[]  @relation("blockedBy")

  // Réactions emoji posées sur les items du fil social (visionnage/commentaire/badge).
  activityReactions  ActivityReaction[]

  // Clubs par série : adhésions de cet utilisateur.
  clubMemberships    ClubMember[]

  // Un compte SSO est identifié de façon unique par (provider, providerId).
  // Les comptes "password" ont providerId = null (SQLite autorise plusieurs NULL).
  @@unique([provider, providerId])
}

// Jeton de réinitialisation de mot de passe, délivré après une
// ré-authentification SSO réussie (Google/Discord). Usage unique, 10 minutes.
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Media {
  id                String    @id @default(cuid())
  type              String // "show" | "movie"

  title             String
  originalTitle     String?
  localizedTitle    String?
  overview          String?
  localizedOverview String?
  // Traductions TMDb par langue de contenu (en/es/de/it/pt) :
  // JSON { "en": { "title": "...", "overview": "..." }, ... }. Le français
  // reste porté par localizedTitle/localizedOverview (jamais dupliqué ici).
  translationsJson  String?

  posterPath        String?
  backdropPath      String?

  firstAirDate      DateTime?
  releaseDate       DateTime?
  year              Int?

  status            String?
  originalLanguage  String?
  originCountry     String?
  genres            String?

  runtime           Int?
  popularity        Float?
  voteAverage       Float?
  voteCount         Int?

  tmdbId            String?
  tvdbId            String?
  imdbId            String?
  igdbId            String?

  sourcePriority    String?
  lastSyncedAt      DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  show              Show?
  movie             Movie?
  game              Game?
  dlcParents        Game[]    @relation("GameDlc")
  statuses          UserMediaStatus[]
  watchEvents       WatchEvent[]
  ratings           Rating[]
  listItems         ListItem[]
  providers         Provider[]
  credits           Credit[]
  importMappings    ImportMapping[]
  comments          Comment[]
  club              Club?

  @@index([type])
  @@index([title])
  @@index([tmdbId])
  @@index([tvdbId])
  @@index([imdbId])
  @@index([igdbId])
}

model Show {
  id                 String    @id @default(cuid())
  mediaId            String    @unique
  media              Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  numberOfSeasons    Int?
  numberOfEpisodes   Int?
  inProduction       Boolean?
  network            String?
  platform           String?
  nextEpisodeAirDate DateTime?
  lastEpisodeAirDate DateTime?
  airTime            String?
  airDay             String?

  // Ordre d'épisodes AUTO retenu pour la série (résolu une fois, partagé par
  // tous les utilisateurs) : 'alternate' quand la numérotation streaming
  // (Disney+…) diffère de l'ordre de diffusion ; null = ordre officiel.
  // episodeOrderCheckedAt marque que l'heuristique a déjà tourné (même si le
  // résultat est null) pour ne pas re-vérifier TheTVDB à chaque fiche.
  defaultEpisodeOrder   String?
  episodeOrderCheckedAt DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  seasons            Season[]
  episodes           Episode[]
  altNumbers         EpisodeAltNumber[]
}

// Numérotation alternative TheTVDB (dvd/absolute/alternate/regional…) d'un
// épisode : les épisodes restent les MÊMES lignes (progression/stats/écritures
// par episodeId inchangées) — seule la (saison, numéro) affichée change quand
// l'ordre effectif d'une série n'est pas l'officiel.
model EpisodeAltNumber {
  id            String  @id @default(cuid())
  showId        String
  show          Show    @relation(fields: [showId], references: [id], onDelete: Cascade)
  orderType     String // 'dvd' | 'absolute' | 'alternate' | 'regional' | 'altdvd'
  episodeId     String
  episode       Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  seasonNumber  Int
  episodeNumber Int

  @@unique([orderType, episodeId])
  @@index([showId, orderType])
}

model Season {
  id           String    @id @default(cuid())
  showId       String
  show         Show      @relation(fields: [showId], references: [id], onDelete: Cascade)

  seasonNumber Int
  title        String?
  overview     String?
  posterPath   String?
  airDate      DateTime?
  episodeCount Int?

  tmdbId       String?
  tvdbId       String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  episodes     Episode[]

  @@unique([showId, seasonNumber])
  @@index([showId])
}

model Episode {
  id                String    @id @default(cuid())

  showId            String
  show              Show      @relation(fields: [showId], references: [id], onDelete: Cascade)

  seasonId          String?
  season            Season?   @relation(fields: [seasonId], references: [id])

  seasonNumber      Int
  episodeNumber     Int
  absoluteNumber    Int?

  title             String
  localizedTitle    String?
  overview          String?
  localizedOverview String?
  stillPath         String?

  airDate           DateTime?
  airTime           String?
  runtime           Int?

  tmdbId            String?
  tvdbId            String?
  imdbId            String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  statuses          UserEpisodeStatus[]
  watchEvents       WatchEvent[]
  ratings           Rating[]
  comments          Comment[]
  altNumbers        EpisodeAltNumber[]

  @@unique([showId, seasonNumber, episodeNumber])
  @@index([showId])
  @@index([seasonId])
  @@index([airDate])
}

model Movie {
  id        String   @id @default(cuid())
  mediaId   String   @unique
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  homepage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Game {
  id           String   @id @default(cuid())
  mediaId      String   @unique
  media        Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  platforms    String?
  developer    String?
  publisher    String?
  gameModes    String?
  steamAppId   String?
  isDlc        Boolean  @default(false)

  parentGameId String?
  parentGame   Media?   @relation("GameDlc", fields: [parentGameId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([steamAppId])
  @@index([parentGameId])
}

model UserMediaStatus {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  mediaId       String
  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  status        String // UserMediaState
  // Jeux : « Je possède » — interrupteur INDÉPENDANT du statut (on peut être
  // « En cours » ET posséder le jeu, ou y jouer via Game Pass sans le posséder).
  isOwned       Boolean   @default(false)
  isFavorite    Boolean   @default(false)
  // Ordre personnalisé des favoris (drag & drop façon TV Time) + date d'ajout
  // aux favoris (tris « Derniers/Premiers ajouts »).
  favoriteOrder Int?
  favoritedAt   DateTime?
  isHidden      Boolean   @default(false)
  personalNote  String?
  rating        Float?
  playtimeMinutes Int?
  // Override PAR UTILISATEUR de l'ordre d'épisodes de la série : 'official'
  // pour forcer l'ordre de diffusion malgré un défaut auto, ou
  // 'dvd'|'alternate'|'absolute'|'regional'|'altdvd' ; null = suivre le
  // défaut de la série (Show.defaultEpisodeOrder).
  episodeOrder  String?

  addedAt       DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  lastWatchedAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, mediaId])
  @@index([userId])
  @@index([mediaId])
  @@index([status])
}

model UserEpisodeStatus {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  episodeId    String
  episode      Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  status       String // EpisodeState
  watchedAt    DateTime?
  rating       Float?
  reaction     String?
  personalNote String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, episodeId])
  @@index([userId])
  @@index([episodeId])
  // Couvre les agrégats gamification (comptes/dates d'épisodes vus par user).
  // L'ancien @@index([status]) seul (faible sélectivité) est retiré.
  @@index([userId, status, watchedAt])
}

model WatchEvent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  mediaId      String
  media        Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  episodeId    String?
  episode      Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  eventType    String // WatchEventType
  eventDate    DateTime
  source       String
  metadataJson String?

  createdAt    DateTime @default(now())

  // Feed social & stats : événements d'un user triés par date.
  @@index([userId, eventDate])
  @@index([eventDate])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  episodeId String?
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mediaId])
  // Lookup « ma note sur cet épisode » (fiches épisode, imports) sans scan.
  @@index([userId, episodeId])
}

model MediaList {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  title          String
  description    String?
  coverMode      String   @default("auto_collage")
  coverUrl       String?
  isFavoriteList Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          ListItem[]
}

model ListItem {
  id        String    @id @default(cuid())
  listId    String
  list      MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)

  mediaId   String
  media     Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  position  Int
  addedAt   DateTime  @default(now())
  createdAt DateTime  @default(now())

  @@unique([listId, mediaId])
  @@index([listId])
  @@index([mediaId])
}

model Provider {
  id               String   @id @default(cuid())
  mediaId          String
  media            Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  countryCode      String
  providerName     String
  providerLogoPath String?
  offerType        String
  url              String?
  source           String
  fetchedAt        DateTime
  createdAt        DateTime @default(now())

  @@index([mediaId])
  @@index([countryCode])
}

model Person {
  id          String   @id @default(cuid())
  name        String
  profilePath String?
  tmdbId      String?
  tvdbId      String?
  imdbId      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  credits     Credit[]

  @@index([name])
}

model Credit {
  id            String   @id @default(cuid())

  mediaId       String
  media         Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  personId      String
  person        Person   @relation(fields: [personId], references: [id])

  roleType      String
  characterName String?
  job           String?
  department    String?
  orderIndex    Int?

  createdAt     DateTime @default(now())

  @@index([mediaId])
  @@index([personId])
}

model Import {
  id          String   @id @default(cuid())
  // Propriétaire : toutes les routes /api/import/tvtime/* sont scopées dessus.
  userId      String?
  source      String
  fileName    String
  fileHash    String
  status      String // ImportStatus
  summaryJson String?
  errorJson   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mappings    ImportMapping[]

  @@unique([userId, fileHash])
  @@index([userId])
}

model ImportMapping {
  id               String   @id @default(cuid())
  importId         String
  import           Import   @relation(fields: [importId], references: [id], onDelete: Cascade)

  sourceRawId      String?
  sourceUrl        String?
  sourceTitle      String
  sourceType       String

  matchedMediaId   String?
  matchedMedia     Media?   @relation(fields: [matchedMediaId], references: [id])
  matchedEpisodeId String?

  matchStatus      String // MatchStatus
  matchScore       Int?

  rawJson          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([importId])
  @@index([matchStatus])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  type         String
  title        String
  body         String?
  imageUrl     String?
  date         DateTime
  isRead       Boolean  @default(false)
  metadataJson String?

  createdAt    DateTime @default(now())

  // Liste des notifications d'un user, triées par date (écran notifications).
  @@index([userId, date])
  @@index([date])
}

// Mémoire du flux Explorer : items déjà servis à un utilisateur. Un item vu
// il y a moins de 3 jours est exclu du tirage suivant (variété réelle entre
// deux refresh) ; les lignes de plus de 14 jours sont purgées au fil de l'eau.
model ExploreImpression {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "show:tmdb:123" | "movie:tmdb:456" | "game:igdb:789"
  itemKey  String
  servedAt DateTime @default(now())

  @@unique([userId, itemKey])
  @@index([userId, servedAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Réglages applicatifs PAR UTILISATEUR. Remplace l'AppSetting global key='app'
// (jadis partagé par tous les comptes : un user changeait les notifs de tout le
// monde). `dataJson` porte l'objet de réglages sérialisé (mêmes clés qu'avant).
model UserSetting {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataJson  String?
  updatedAt DateTime @updatedAt
}

model ApiCache {
  id           String   @id @default(cuid())
  source       String
  cacheKey     String
  responseJson String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([source, cacheKey])
  @@index([expiresAt])
}

// --- Social (façon TV Time) -------------------------------------------------

// Abonnement asymétrique : followerId suit followingId.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Commentaire sur une série (mediaId) ou un épisode précis (episodeId).
model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episodeId String?
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  // Fil de discussion : une réponse pointe vers son commentaire parent.
  parentId  String?
  parent    Comment?  @relation("thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("thread")
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions CommentReaction[]
  reports   Report[]

  @@index([mediaId])
  @@index([episodeId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

// --- Gamification (spec 2026-07-16) ------------------------------------------

// Progression agrégée : recalculée intégralement depuis les données (recompute
// idempotent) — jamais incrémentée à la main.
model UserProgress {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp            Int      @default(0)
  level         Int      @default(1)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// Palier de badge débloqué (une ligne par palier, tier 1 = bronze …).
model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String
  tier       Int
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId, tier])
  @@index([userId])
  @@index([unlockedAt])
}

// Défi mensuel accompli ("2026-07-marathon") — idempotent via l'unicité.
model UserChallenge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  completedAt DateTime @default(now())

  @@unique([userId, challengeId])
}

// Réaction emoji à un commentaire (une par utilisateur et par commentaire).
model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  // Un utilisateur peut poser plusieurs emojis différents sur un même commentaire.
  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

// Réaction emoji à un item du fil social. La cible est polymorphe :
// kind 'watch' → WatchEvent.id, 'comment' → Comment.id, 'badge' → UserBadge.id
// (refId, pas de FK : les cibles vivent dans trois tables différentes).
model ActivityReaction {
  id        String   @id @default(cuid())
  kind      String   // 'watch' | 'comment' | 'badge'
  refId     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  // Toggle par emoji : un utilisateur ne pose chaque emoji qu'une fois par cible.
  @@unique([kind, refId, userId, emoji])
  @@index([kind, refId])
  // Purge « toutes les réactions d'un utilisateur » (suppression de compte).
  @@index([userId])
}

// --- Clubs par série (v1) -----------------------------------------------------

// Un club par média (série/film/jeu), créé à la volée par le premier membre.
model Club {
  id          String       @id @default(cuid())
  mediaId     String       @unique
  media       Media        @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime     @default(now())
  members     ClubMember[]
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([clubId, userId])
  @@index([userId])
}

// Signalement d'une œuvre inappropriée (ex. hentai passé à travers le filtre)
// OU d'un commentaire abusif (exigence stores : UGC signalable, Apple 1.2).
// Stocké pour un tri manuel ultérieur (pas d'écran admin pour l'instant).
model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  mediaId    String?  // si l'œuvre existe en local
  mediaType  String   // 'show' | 'movie' | 'game' | 'comment'
  tmdbId     String?
  igdbId     String?
  // Commentaire signalé (mediaType 'comment') — supprimé avec le commentaire.
  commentId  String?
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  title      String
  reason     String   // ex. 'adult' (contenu 18+/porno), 'abuse' (commentaire) — extensible
  note       String?
  status     String   @default("pending") // pending | resolved | dismissed
  createdAt  DateTime @default(now())

  @@index([status, createdAt])
  @@index([reporterId])
}

// Blocage d'un utilisateur (exigence stores : pouvoir bloquer un auteur d'UGC).
// Modèle simple façon « mute » Twitter, UNIDIRECTIONNEL : les contenus du
// bloqué disparaissent des vues du bloqueur (fil, commentaires, recherche,
// classement) — l'inverse n'est PAS filtré (être bloqué ne cache rien).
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blockedBy", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}
