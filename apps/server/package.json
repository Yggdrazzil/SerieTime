    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "@serietime/core": "workspace:*",
    "@serietime/types": "workspace:*",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
