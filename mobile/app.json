{
  "expo": {
    "name": "SerieTime",
    "slug": "serietime",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "serietime",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#FFD400",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.serietime.app"
    },
    "android": {
      "package": "com.serietime.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFD400"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "serverUrl": ""
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
